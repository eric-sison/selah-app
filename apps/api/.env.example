# Server
HOST=0.0.0.0
PORT=4000
LOG_LEVEL=info

# Comma-separated list of origins allowed to call the API (CORS).
ALLOWED_ORIGINS=

# Postgres connection string (see docker-compose.yml for local credentials)
DATABASE_URL=

# Auth (better-auth)
# Secret used to sign sessions/tokens - min 32 chars.
BETTER_AUTH_SECRET=

# Public URL of this API, used by better-auth for callback URLs. Optional locally.
BETTER_AUTH_URL=

# Public URL of the web app, used for email links (invites, verification, etc).
WEB_URL=

# Facebook social login (better-auth provider)
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Seeds the initial admin user via `pnpm db:seed:admin` - not read at server boot.
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=

# Object storage (Garage, S3-compatible - see docker-compose.yml).
# Run `pnpm garage:init` once locally to create the bucket/key and print these values.
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Stem separation worker (services/stem-worker) - a standalone service, not
# part of this pnpm workspace. See services/stem-worker/.env.example for its
# own config, including the S3/Garage credentials it uses to upload stems.
# This API's own externally-reachable base URL - handed to the worker so its
# completion callback can resolve back here (matters once the worker runs on
# a different host, e.g. in production).
API_PUBLIC_URL=http://localhost:4000
# URL apps/api posts separation jobs to.
STEM_WORKER_URL=
# Shared secret apps/api sends the worker (min 32 chars) - must match the
# worker's own STEM_WORKER_SECRET.
STEM_WORKER_SECRET=
# Shared secret the worker sends back on its completion callback (min 32
# chars) - must match the worker's own STEM_CALLBACK_SECRET.
STEM_CALLBACK_SECRET=
