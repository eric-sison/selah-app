{
  "openapi": "3.0.0",
  "info": {
    "title": "Selah API",
    "description": "This API provides access to application resources and operations.",
    "version": "1.0.0"
  },
  "components": {
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "number"
          },
          "message": {
            "type": "string"
          },
          "code": {
            "type": "string"
          }
        },
        "required": [
          "status",
          "message"
        ]
      }
    },
    "parameters": {}
  },
  "paths": {
    "/api/health": {
      "get": {
        "operationId": "getHealth",
        "tags": [
          "Health"
        ],
        "summary": "Liveness check",
        "description": "Confirms the API process is up and able to respond to requests. This does not verify downstream dependencies (database, SMTP, etc.) so a 200 here does not guarantee those are reachable.",
        "responses": {
          "200": {
            "description": "Service is healthy and running.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "number",
                      "description": "HTTP status code, duplicated from the response status.",
                      "example": 200
                    },
                    "message": {
                      "type": "string",
                      "description": "Human-readable summary of the health check result.",
                      "example": "Service is healthy and running."
                    },
                    "code": {
                      "type": "string",
                      "description": "Machine-readable status code.",
                      "example": "OK"
                    }
                  },
                  "required": [
                    "status",
                    "message",
                    "code"
                  ]
                },
                "example": {
                  "status": 200,
                  "message": "Service is healthy and running.",
                  "code": "OK"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error. Something went wrong.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "status": 500,
                  "message": "Internal server error. Something went wrong."
                }
              }
            }
          }
        }
      }
    },
    "/api/invitations": {
      "post": {
        "operationId": "createInvitation",
        "tags": [
          "Invitations"
        ],
        "summary": "Invite a new user",
        "description": "Admin-only. Generates an invitation link (valid for 2 hours) and emails it to the given address.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email"
                  }
                },
                "required": [
                  "email"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Invitation created.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "email": {
                      "type": "string"
                    },
                    "expiresAt": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "email",
                    "expiresAt"
                  ]
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized. Missing or invalid authentication.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "status": 401,
                  "message": "Unauthorized. Missing or invalid authentication."
                }
              }
            }
          },
          "403": {
            "description": "Forbidden. Insufficient permissions.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "status": 403,
                  "message": "Forbidden. Insufficient permissions."
                }
              }
            }
          },
          "409": {
            "description": "Conflict. Resource already exists.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "status": 409,
                  "message": "Conflict. Resource already exists."
                }
              }
            }
          },
          "422": {
            "description": "Unprocessable. Request body failed validation.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "status": 422,
                  "message": "Unprocessable. Request body failed validation."
                }
              }
            }
          }
        }
      }
    },
    "/api/invitations/{token}": {
      "get": {
        "operationId": "getInvitation",
        "tags": [
          "Invitations"
        ],
        "summary": "Look up an invitation by token",
        "description": "Public. Used by the sign-up page to check whether a token is still valid before showing the form.",
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "required": true,
            "name": "token",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "Invitation is valid.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "email": {
                      "type": "string"
                    },
                    "expiresAt": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "email",
                    "expiresAt"
                  ]
                }
              }
            }
          },
          "404": {
            "description": "Not found. Resource does not exist.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "status": 404,
                  "message": "Not found. Resource does not exist."
                }
              }
            }
          }
        }
      }
    },
    "/api/songs": {
      "post": {
        "operationId": "createSong",
        "tags": [
          "Songs"
        ],
        "summary": "Upload a song",
        "description": "Any authenticated user can upload a song's audio file and basic metadata.",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "title": {
                    "type": "string",
                    "minLength": 1
                  },
                  "artist": {
                    "type": "string"
                  },
                  "musicalKey": {
                    "type": "string"
                  },
                  "tempo": {
                    "type": "integer",
                    "minimum": 0,
                    "exclusiveMinimum": true
                  },
                  "album": {
                    "type": "string"
                  },
                  "releaseDate": {
                    "type": "string",
                    "format": "date"
                  },
                  "file": {
                    "type": "string",
                    "format": "binary"
                  },
                  "albumArt": {
                    "type": "string",
                    "format": "binary"
                  }
                },
                "required": [
                  "title",
                  "file"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Song uploaded.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string"
                    },
                    "title": {
                      "type": "string"
                    },
                    "artist": {
                      "type": "string",
                      "nullable": true
                    },
                    "musicalKey": {
                      "type": "string",
                      "nullable": true
                    },
                    "tempo": {
                      "type": "number",
                      "nullable": true
                    },
                    "album": {
                      "type": "string",
                      "nullable": true
                    },
                    "releaseDate": {
                      "type": "string",
                      "nullable": true
                    },
                    "originalFileName": {
                      "type": "string"
                    },
                    "mimeType": {
                      "type": "string"
                    },
                    "fileSizeBytes": {
                      "type": "number"
                    },
                    "uploader": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "string"
                        },
                        "name": {
                          "type": "string"
                        }
                      },
                      "required": [
                        "id",
                        "name"
                      ]
                    },
                    "createdAt": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "id",
                    "title",
                    "artist",
                    "musicalKey",
                    "tempo",
                    "album",
                    "releaseDate",
                    "originalFileName",
                    "mimeType",
                    "fileSizeBytes",
                    "uploader",
                    "createdAt"
                  ]
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized. Missing or invalid authentication.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "status": 401,
                  "message": "Unauthorized. Missing or invalid authentication."
                }
              }
            }
          },
          "413": {
            "description": "Payload too large. Request body exceeds the maximum allowed size.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "status": 413,
                  "message": "Payload too large. Request body exceeds the maximum allowed size."
                }
              }
            }
          },
          "422": {
            "description": "Unprocessable. Request body failed validation.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "status": 422,
                  "message": "Unprocessable. Request body failed validation."
                }
              }
            }
          }
        }
      },
      "get": {
        "operationId": "listSongs",
        "tags": [
          "Songs"
        ],
        "summary": "List uploaded songs",
        "description": "Any authenticated user can list all uploaded songs.",
        "responses": {
          "200": {
            "description": "List of songs.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "string"
                      },
                      "title": {
                        "type": "string"
                      },
                      "artist": {
                        "type": "string",
                        "nullable": true
                      },
                      "musicalKey": {
                        "type": "string",
                        "nullable": true
                      },
                      "tempo": {
                        "type": "number",
                        "nullable": true
                      },
                      "album": {
                        "type": "string",
                        "nullable": true
                      },
                      "releaseDate": {
                        "type": "string",
                        "nullable": true
                      },
                      "originalFileName": {
                        "type": "string"
                      },
                      "mimeType": {
                        "type": "string"
                      },
                      "fileSizeBytes": {
                        "type": "number"
                      },
                      "uploader": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "string"
                          },
                          "name": {
                            "type": "string"
                          }
                        },
                        "required": [
                          "id",
                          "name"
                        ]
                      },
                      "createdAt": {
                        "type": "string"
                      }
                    },
                    "required": [
                      "id",
                      "title",
                      "artist",
                      "musicalKey",
                      "tempo",
                      "album",
                      "releaseDate",
                      "originalFileName",
                      "mimeType",
                      "fileSizeBytes",
                      "uploader",
                      "createdAt"
                    ]
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized. Missing or invalid authentication.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "status": 401,
                  "message": "Unauthorized. Missing or invalid authentication."
                }
              }
            }
          }
        }
      }
    },
    "/api/songs/{id}/stream-url": {
      "get": {
        "operationId": "getSongStreamUrl",
        "tags": [
          "Songs"
        ],
        "summary": "Get a temporary playback URL for a song",
        "description": "Any authenticated user can request a short-lived, signed URL for streaming a song's audio file directly from storage.",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "Signed playback URL.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "url": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "url"
                  ]
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized. Missing or invalid authentication.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "status": 401,
                  "message": "Unauthorized. Missing or invalid authentication."
                }
              }
            }
          },
          "404": {
            "description": "Not found. Resource does not exist.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "status": 404,
                  "message": "Not found. Resource does not exist."
                }
              }
            }
          }
        }
      }
    },
    "/api/songs/{id}/download-url": {
      "get": {
        "operationId": "getSongDownloadUrl",
        "tags": [
          "Songs"
        ],
        "summary": "Get a temporary download URL for a song",
        "description": "Any authenticated user can request a short-lived, signed URL for downloading a song's original audio file.",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "Signed download URL.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "url": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "url"
                  ]
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized. Missing or invalid authentication.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "status": 401,
                  "message": "Unauthorized. Missing or invalid authentication."
                }
              }
            }
          },
          "404": {
            "description": "Not found. Resource does not exist.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "status": 404,
                  "message": "Not found. Resource does not exist."
                }
              }
            }
          }
        }
      }
    },
    "/api/songs/{id}": {
      "delete": {
        "operationId": "deleteSong",
        "tags": [
          "Songs"
        ],
        "summary": "Delete a song",
        "description": "Admin-only. Deletes the song's database record and its audio file and album art (if any) from storage.",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "responses": {
          "204": {
            "description": "Song deleted."
          },
          "401": {
            "description": "Unauthorized. Missing or invalid authentication.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "status": 401,
                  "message": "Unauthorized. Missing or invalid authentication."
                }
              }
            }
          },
          "403": {
            "description": "Forbidden. Insufficient permissions.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "status": 403,
                  "message": "Forbidden. Insufficient permissions."
                }
              }
            }
          },
          "404": {
            "description": "Not found. Resource does not exist.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "status": 404,
                  "message": "Not found. Resource does not exist."
                }
              }
            }
          }
        }
      }
    }
  }
}
