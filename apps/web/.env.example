# Base URL of the API (apps/api). Server-side only - used by next.config.ts's
# rewrite, lib/api-client.ts, lib/session.ts, and the sign-up invite lookup.
# Defaults to http://localhost:4000 when unset.
API_URL=

# ============================================================================
# E2E Test Credentials
# ============================================================================

# Copy to apps/web/.env.test (gitignored) and fill in credentials for an
# account that already exists in your local database - e2e/auth.setup.ts
# signs in with these to build the storageState reused by authenticated
# tests. Seed one via `pnpm db:seed:admin` (apps/api) with matching values,
# or use any other account you've already created.
E2E_EMAIL=
E2E_PASSWORD=

# Non-admin ("user" role) account - e2e/member.setup.ts signs in with these
# for role-gated UI tests (e.g. verifying Delete is hidden for non-admins).
# Must go through the real invite + sign-up flow (admin invites the email,
# accept the link, verify via the emailed link) since role="admin" is only
# ever set by db:seed:admin - there's no "make this user an admin" UI.
E2E_MEMBER_EMAIL=
E2E_MEMBER_PASSWORD=