# Must match apps/api's STEM_WORKER_SECRET - authenticates the job POST
# apps/api sends to this service.
STEM_WORKER_SECRET=

# Must match apps/api's STEM_CALLBACK_SECRET - sent on this worker's
# completion callback back to apps/api.
STEM_CALLBACK_SECRET=

# Garage/S3-compatible storage this worker uploads stems to directly. Use a
# separate, write-only key from apps/api's own S3_ACCESS_KEY_ID (see
# scripts/garage-init.sh's "stem-worker-key" for how to create one) rather
# than reusing apps/api's credentials.
S3_ENDPOINT=http://localhost:3900
S3_REGION=garage
S3_BUCKET=selah-songs
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# htdemucs_6s is Demucs' 6-source model (vocals/drums/bass/guitar/piano/
# other) - the only pretrained model that can isolate piano. Set to
# "htdemucs" for the plain 4-stem model (better vocals/drums/bass/other
# quality, no guitar/piano) if piano separation isn't needed.
DEMUCS_MODEL=htdemucs_6s

# flac (lossless, default) | aac | mp3 - see app/encode.py.
OUTPUT_FORMAT=flac

# How many separations to run at once - each is CPU/RAM (or GPU) heavy.
MAX_CONCURRENT_JOBS=1

WORK_DIR=/tmp/stem-worker
